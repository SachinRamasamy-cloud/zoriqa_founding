page Dashboard {
  title "AUIG Dashboard"

  view {
    section {
      h1 "Dashboard" bold
      p "Simple reusable UI generated from AUIG" muted

      row gap-large {
        card {
          p "Total Users" muted
          h2 "1,240"S bold
        }

        card {
          p "Revenue" muted
          h2 "$18,900" bold
        }

        card {
          p "Active Projects" muted
          h2 "32" bold
        }
      }

      btn "Export Report" primary
    }
  }
}
